include "test"
| include "jq"
|

def assert_jq(program, input, expected):
  let result = jq_run_first(program, input)
  | assert_eq(result, expected)
end

def assert_jq_multi(program, input, expected):
  let result = jq_run(program, input)
  | assert_eq(result, expected)
end

# ===== Identity and Literals =====

def test_identity():
  assert_jq(".", 42, 42)
  | assert_jq(".", "hello", "hello")
  | assert_jq(".", None, None)
  | assert_jq(".", true, true)
  | assert_jq(".", [1,2,3], [1,2,3])
  | assert_jq(".", {"a":1}, {"a":1})
end

def test_literals():
  assert_jq("42", None, 42)
  | assert_jq("\"hello\"", None, "hello")
  | assert_jq("null", None, None)
  | assert_jq("true", None, true)
  | assert_jq("false", None, false)
end

# ===== Field Access =====

def test_field_access():
  assert_jq(".foo", {"foo": 42}, 42)
  | assert_jq(".foo.bar", {"foo": {"bar": 99}}, 99)
  | assert_jq(".missing", {"foo": 1}, None)
  | assert_jq(".foo", None, None)
end

# ===== Array Index =====

def test_array_index():
  assert_jq(".[0]", [1,2,3], 1)
  | assert_jq(".[2]", [1,2,3], 3)
  | assert_jq(".[-1]", [1,2,3], 3)
  | assert_jq(".[10]", [1,2,3], None)
end

# ===== Array/String Slice =====

def test_slice():
  assert_jq(".[1:3]", [1,2,3,4,5], [2,3])
  | assert_jq(".[0:2]", "hello", "he")
  | assert_jq(".[:2]", [1,2,3], [1,2])
  | assert_jq(".[2:]", [1,2,3,4], [3,4])
end

# ===== Pipe =====

def test_pipe():
  assert_jq(". | . + 1", 5, 6)
  | assert_jq(".a | . * 2", {"a": 5}, 10)
end

# ===== Comma (stream) =====

def test_comma():
  assert_jq_multi("1, 2, 3", None, [1, 2, 3])
  | assert_jq_multi(".a, .b", {"a": 1, "b": 2}, [1, 2])
end

# ===== Array Constructor =====

def test_array_constructor():
  assert_jq("[1, 2, 3]", None, [1, 2, 3])
  | assert_jq("[.[] | . * 2]", [1,2,3], [2,4,6])
  | assert_jq("[.a, .b]", {"a": 1, "b": 2}, [1, 2])
end

# ===== Object Constructor =====

def test_object_constructor():
  assert_jq("{a: 1, b: 2}", None, {"a": 1, "b": 2})
  | assert_jq("{x: .foo}", {"foo": 42}, {"x": 42})
end

# ===== Arithmetic =====

def test_arithmetic():
  assert_jq(". + 1", 5, 6)
  | assert_jq(". - 1", 5, 4)
  | assert_jq(". * 3", 4, 12)
  | assert_jq(". / 2", 10, 5)
  | assert_jq(". % 3", 7, 1)
  | assert_jq(".a + .b", {"a": 1, "b": 2}, 3)
end

# ===== String Operations =====

def test_string_ops():
  assert_jq(". + \" world\"", "hello", "hello world")
  | assert_jq("startswith(\"he\")", "hello", true)
  | assert_jq("endswith(\"lo\")", "hello", true)
  | assert_jq("ascii_downcase", "HELLO", "hello")
  | assert_jq("ascii_upcase", "hello", "HELLO")
  | assert_jq("split(\",\")", "a,b,c", ["a","b","c"])
  | assert_jq("join(\",\")", ["a","b","c"], "a,b,c")
  | assert_jq("ltrimstr(\"he\")", "hello", "llo")
  | assert_jq("rtrimstr(\"llo\")", "hello", "he")
end

# ===== Comparison =====

def test_comparison():
  assert_jq(". == 42", 42, true)
  | assert_jq(". != 42", 43, true)
  | assert_jq(". < 10", 5, true)
  | assert_jq(". > 10", 5, false)
  | assert_jq(". <= 5", 5, true)
  | assert_jq(". >= 5", 5, true)
end

# ===== Boolean Logic =====

def test_boolean():
  assert_jq("true and false", None, false)
  | assert_jq("true or false", None, true)
  | assert_jq("true | not", None, false)
  | assert_jq("null | not", None, true)
end

# ===== Alternative Operator =====

def test_alternative():
  assert_jq(". // 42", None, 42)
  | assert_jq(". // 42", false, 42)
  | assert_jq(". // 42", 99, 99)
end

# ===== If-Then-Else =====

def test_if_then_else():
  assert_jq("if . > 0 then \"pos\" else \"neg\" end", 5, "pos")
  | assert_jq("if . > 0 then \"pos\" else \"neg\" end", -3, "neg")
  | assert_jq("if . == 1 then \"one\" elif . == 2 then \"two\" else \"other\" end", 2, "two")
end

# ===== Try-Catch =====

def test_try_catch():
  assert_jq("try .foo catch \"err\"", "not_object", "err")
  | assert_jq("try error(\"boom\") catch \"caught\"", None, "caught")
end

# ===== Length =====

def test_length():
  assert_jq("length", [1,2,3], 3)
  | assert_jq("length", "hello", 5)
  | assert_jq("length", {"a":1,"b":2}, 2)
  | assert_jq("length", None, 0)
  | assert_jq("length", -5, 5)
end

# ===== Keys and Values =====

def test_keys_values():
  assert_jq("keys", {"b":2,"a":1}, ["a","b"])
  | assert_jq("keys", [10,20,30], [0,1,2])
  | assert_jq("[.[] | values]", {"a":1,"b":None}, [1])
  | assert_jq("values", 42, 42)
  | assert_jq_multi("values", None, [])
end

# ===== Has =====

def test_has():
  assert_jq("has(\"foo\")", {"foo":1}, true)
  | assert_jq("has(\"bar\")", {"foo":1}, false)
  | assert_jq("has(0)", [1,2,3], true)
  | assert_jq("has(5)", [1,2,3], false)
end

# ===== Map and Select =====

def test_map_select():
  assert_jq("map(. * 2)", [1,2,3], [2,4,6])
  | assert_jq("map(select(. > 2))", [1,2,3,4], [3,4])
  | assert_jq("[.[] | select(. > 2)]", [1,2,3,4], [3,4])
end

# ===== Type Builtins =====

def test_type_builtins():
  assert_jq("type", 42, "number")
  | assert_jq("type", "hello", "string")
  | assert_jq("type", true, "boolean")
  | assert_jq("type", None, "null")
  | assert_jq("type", [1,2], "array")
  | assert_jq("type", {"a":1}, "object")
end

# ===== Sorting =====

def test_sorting():
  assert_jq("sort", [3,1,2], [1,2,3])
  | assert_jq("sort_by(.age)", [{"age":3},{"age":1},{"age":2}], [{"age":1},{"age":2},{"age":3}])
  | assert_jq("reverse", [1,2,3], [3,2,1])
end

# ===== Unique and Group =====

def test_unique_group():
  assert_jq("unique", [1,2,1,3,2], [1,2,3])
  | assert_jq("unique_by(.x)", [{"x":1,"y":1},{"x":2},{"x":1,"y":2}], [{"x":1,"y":1},{"x":2}])
  | assert_jq("group_by(.x) | length", [{"x":1},{"x":2},{"x":1}], 2)
end

# ===== Min and Max =====

def test_min_max():
  assert_jq("min", [3,1,2], 1)
  | assert_jq("max", [3,1,2], 3)
  | assert_jq("min_by(.age)", [{"age":3},{"age":1}], {"age":1})
  | assert_jq("max_by(.age)", [{"age":3},{"age":1}], {"age":3})
end

# ===== Flatten =====

def test_flatten():
  assert_jq("flatten", [[1,2],[3,[4]]], [1,2,3,4])
  | assert_jq("flatten(1)", [[1,[2]],[3]], [1,[2],3])
end

# ===== Add =====

def test_add():
  assert_jq("add", [1,2,3], 6)
  | assert_jq("add", ["a","b","c"], "abc")
  | assert_jq("add", [[1,2],[3,4]], [1,2,3,4])
end

# ===== Any and All =====

def test_any_all():
  assert_jq("any(.[]; . > 3)", [1,2,3,4], true)
  | assert_jq("any(.[]; . > 10)", [1,2,3,4], false)
  | assert_jq("all(.[]; . > 0)", [1,2,3,4], true)
  | assert_jq("all(.[]; . > 2)", [1,2,3,4], false)
end

# ===== Reduce =====

def test_reduce():
  assert_jq("reduce .[] as $x (0; . + $x)", [1,2,3,4], 10)
  | assert_jq("reduce .[] as $x (\"\"; . + $x)", ["a","b","c"], "abc")
end

# ===== As Binding =====

def test_as_binding():
  assert_jq(". as $x | $x * $x", 5, 25)
  | assert_jq("[.[] as $x | $x * 2]", [1,2,3], [2,4,6])
end

# ===== Entry Operations =====

def test_entry_ops():
  assert_jq("to_entries | length", {"a":1,"b":2}, 2)
  | assert_jq("to_entries[0].key", {"a":1}, "a")
  | assert_jq("from_entries", [{"key":"a","value":1}], {"a":1})
  | assert_jq("with_entries({key: .key, value: (.value + 1)})", {"a":1,"b":2}, {"a":2,"b":3})
end

# ===== Contains =====

def test_contains():
  assert_jq("contains(\"lo\")", "hello", true)
  | assert_jq("contains([2,3])", [1,2,3,4], true)
end

# ===== Index/Rindex =====

def test_index_rindex():
  assert_jq("index(2)", [1,2,3,2], 1)
  | assert_jq("rindex(2)", [1,2,3,2], 3)
  | assert_jq("index(\"l\")", "hello", 2)
end

# ===== Math =====

def test_math():
  assert_jq("floor", 3.7, 3)
  | assert_jq("ceil", 3.2, 4)
  | assert_jq("round", 3.5, 4)
  | assert_jq("sqrt", 9, 3)
  | assert_jq("fabs", -5, 5)
end

# ===== User Defined Functions =====

def test_user_functions():
  assert_jq("def double: . * 2; double", 5, 10)
  | assert_jq("def add(x): . + x; add(3)", 5, 8)
  | assert_jq("def sq: . * .; [1,2,3] | map(sq)", None, [1,4,9])
end

# ===== Range =====

def test_range():
  assert_jq_multi("[range(3)]", None, [[0,1,2]])
  | assert_jq_multi("[range(2;5)]", None, [[2,3,4]])
end

# ===== Recurse =====

def test_recurse():
  let result = jq_run(".. | numbers", {"a": 1, "b": {"c": 2}})
  | assert(contains(result, 1))
  | assert(contains(result, 2))
end

# ===== Path Operations =====

def test_paths():
  assert_jq("getpath([\"a\",\"b\"])", {"a":{"b":42}}, 42)
  | assert_jq("setpath([\"a\"]; 99)", {}, {"a":99})
  | assert_jq("delpaths([[\"a\"]])", {"a":1,"b":2}, {"b":2})
end

# ===== String Tests =====

def test_string_builtins():
  assert_jq("test(\"^[0-9]+$\")", "123", true)
  | assert_jq("test(\"^[0-9]+$\")", "abc", false)
  | assert_jq("gsub(\"a\"; \"x\")", "banana", "bxnxnx")
  | assert_jq("tostring", 42, "42")
  | assert_jq("tonumber", "42", 42)
  | assert_jq("explode", "ab", [97, 98])
  | assert_jq("implode", [97, 98], "ab")
end

# ===== First/Last/Limit =====

def test_first_last_limit():
  assert_jq_multi("first(range(3))", None, [0])
  | assert_jq_multi("last(range(3))", None, [2])
  | assert_jq_multi("[limit(2; range(5))]", None, [[0,1]])
end

# ===== Foreach =====

def test_foreach():
  assert_jq("[foreach .[] as $x (0; . + $x)]", [1,2,3,4], [1,3,6,10])
end

# ===== Object Merge =====

def test_object_merge():
  assert_jq(". + {b: 3}", {"a": 1, "b": 2}, {"a": 1, "b": 3})
end

# ===== Null Propagation =====

def test_null_propagation():
  assert_jq(".foo.bar", None, None)
  | assert_jq(".[5]", [1,2,3], None)
end
